@using ObsidianArchive.Models.ViewModels
@model ProductVM

<div class="container-fluid py-3">
    <a asp-controller="Product" asp-action="Index" class="text-decoration-none text-secondary small fw-medium d-inline-flex align-items-center gap-1 mb-3">
        <i class="bi bi-arrow-left"></i> Back to products
    </a>
    <div class="card border shadow-sm overflow-hidden">
        <div class="card-header text-white py-3 px-4" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Update Product</h5>
            <p class="mb-0 small" style="color: #1DB954;">Edit an existing product</p>
        </div>
        <div class="card-body p-4">
            <form method="post" enctype="multipart/form-data">
                <input asp-for="Product.Id" hidden />
                <input asp-for="Product.ImageUrl" hidden />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Product.Title" class="form-label fw-semibold small">1 Name</label>
                    <input type="text" name="Product.Title" asp-for="Product.Title" class="form-control" placeholder="Enter product title" />
                    <span asp-validation-for="Product.Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.Description" class="form-label fw-semibold small">Description</label>
                    <textarea asp-for="Product.Description" hidden class="form-control" placeholder="Enter description"></textarea>
                    <div id="quill-editor" style="height: 200px;"></div>
                    <span asp-validation-for="Product.Description" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.ISBN" class="form-label fw-semibold small">ISBN</label>
                    <input type="text" name="Product.ISBN" asp-for="Product.ISBN" class="form-control" placeholder="Enter ISBN" />
                    <span asp-validation-for="Product.ISBN" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.Author" class="form-label fw-semibold small">Author</label>
                    <input type="text" name="Product.Author" asp-for="Product.Author" class="form-control" placeholder="Enter Author" />
                    <span asp-validation-for="Product.Author" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.ListPrice" class="form-label fw-semibold small"></label>
                    <input type="text" name="Product.ListPrice" asp-for="Product.ListPrice" class="form-control" placeholder="Enter ListPrice" />
                    <span asp-validation-for="Product.ListPrice" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.Price" class="form-label fw-semibold small"></label>
                    <input type="text" name="Product.Price" asp-for="Product.Price" class="form-control" placeholder="Enter Price" />
                    <span asp-validation-for="Product.Price" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.Price50" class="form-label fw-semibold small"></label>
                    <input type="text" name="Product.Price50" asp-for="Product.Price50" class="form-control" placeholder="Enter Price50" />
                    <span asp-validation-for="Product.Price50" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Product.Price100" class="form-label fw-semibold small"></label>
                    <input type="text" name="Product.Price100" asp-for="Product.Price100" class="form-control" placeholder="Enter Price100" />
                    <span asp-validation-for="Product.Price100" class="text-danger small"></span>
                </div>
                <div class="mt-3">
                    <label asp-for="Product.CategoryId" class="form-label fw-semibold small"></label>
                    <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-control">
                        <option disabled selected>--Select Category--</option>
                    </select>
                    <span asp-validation-for="Product.CategoryId" class="text-danger small"></span>
                </div>
                <div class="mt-3">
                    <label class="form-label" fw-semibold small">Product Image</label>
                    <div class="border border-2 border-dashed rounded p-4 text-center">
                        <i class="bi bi-cloud-upload fs-4 text-secondary"></i>
                        <input type="file" name="file" accept="image/*" class="form-control form-control-sm mt-2" />
                        <p class="text-secondary mt-1 mb-0" style="font-size: 0.75rem;">Upload a single product image (JPG, PNG)</p>
                    </div>
                </div>

                <div class="border rounded p-3 bg-light text-center">
                    <p class="text-uppercase fw-semibold text-secondary mb-2" style="font-size:0.65rem; letter-spacing: 0.1em;">Current image</p>
                    <img src="@Model.Product.ImageUrl" class="img-fluid rounded shadow-sm mb-2" />
                    <p class="text-secondary mb-0" style="font-size: 0.75rem;">Upload a new image to replace this one</p>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-accent fw-semibold">Update Product</button>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-light fw-medium">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- Include stylesheet -->
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>

    <!-- Initialize Quill editor -->
    <script>
        const quill = new Quill('#quill-editor', {
        theme: 'snow'
        });

        const textAreaDesc = document.querySelector('textarea[name="Product.Description"]');

        // load existing content and auto-sync
        if (textAreaDesc.value) quill.root.innerHTML = textAreaDesc.value;

        quill.on('text-change', ()=>textAreaDesc.value = quill.root.innerHTML);
    </script>
}