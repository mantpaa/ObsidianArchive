@using ObsidianArchive.Models
@model Product

<div class="container-fluid py-3">
    <a asp-controller="Product" asp-action="Index" class="text-decoration-none text-secondary small fw-medium d-inline-flex align-items-center gap-1 mb-3">
        <i class="bi bi-arrow-left"></i> Back to products
    </a>
    <div class="card border shadow-sm overflow-hidden">
        <div class="card-header text-white py-3 px-4" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Create Product</h5>
            <p class="mb-0 small" style="color: #1DB954;">Add a new Product for your products</p>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <input asp-for="Id" hidden />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold small">1 Name</label>
                    <input type="text" name="Title" asp-for="Title" class="form-control" placeholder="Enter product title" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold small">Description</label>
                    <input type="text" name="Description" asp-for="Description" class="form-control" placeholder="Enter description" />
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ISBN" class="form-label fw-semibold small">ISBN</label>
                    <input type="text" name="ISBN" asp-for="ISBN" class="form-control" placeholder="Enter ISBN" />
                    <span asp-validation-for="ISBN" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Author" class="form-label fw-semibold small">Author</label>
                    <input type="text" name="Author" asp-for="Author" class="form-control" placeholder="Enter Author" />
                    <span asp-validation-for="Author" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ListPrice" class="form-label fw-semibold small"></label>
                    <input type="text" name="ListPrice" asp-for="ListPrice" class="form-control" placeholder="Enter ListPrice" />
                    <span asp-validation-for="ListPrice" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-semibold small"></label>
                    <input type="text" name="Price" asp-for="Price" class="form-control" placeholder="Enter Price" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price50" class="form-label fw-semibold small"></label>
                    <input type="text" name="Price50" asp-for="Price50" class="form-control" placeholder="Enter Price50" />
                    <span asp-validation-for="Price50" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price100" class="form-label fw-semibold small"></label>
                    <input type="text" name="Price100" asp-for="Price100" class="form-control" placeholder="Enter Price100" />
                    <span asp-validation-for="Price100" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label fw-semibold small"></label>
                    <input type="text" name="ImageUrl" asp-for="ImageUrl" class="form-control" placeholder="Enter ImageUrl" />
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-accent fw-semibold">Update Product</button>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-light fw-medium">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}